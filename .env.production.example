APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=sqlite:///app/data/netking.db
APP_ADMIN_USERNAME=netking-admin
APP_ADMIN_PASSWORD=replace-with-strong-admin-password
APP_SESSION_TOKEN=replace-with-long-random-token-min-32-chars
APP_SESSION_TTL_SECS=43200
APP_CRYPTO_KEY=replace-with-strong-crypto-passphrase
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=
MIKROTIK_ALLOW_INSECURE_TLS=true
MIKROTIK_REQUEST_TIMEOUT_SECS=20
MAX_SCAN_CONCURRENCY=8
SCAN_COOLDOWN_SECS=20
